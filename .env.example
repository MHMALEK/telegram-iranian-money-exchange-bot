# Telegram: create a bot via @BotFather
TELEGRAM_BOT_TOKEN=

# Local SQLite (default): sqlite+aiosqlite:///./data/app.db
# Free Postgres (Neon, Supabase, etc.):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/postgres

DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Optional: API base URL if the bot should call the HTTP API (same machine example)
# API_BASE_URL=http://127.0.0.1:8000

# User-visible copy: exchange_money_bot/locales/fa.py (add locales/en.py later).
# Default language: DEFAULT_LOCALE in exchange_money_bot/constants.py.

# Listings channel: where offers are posted; bot must be admin (post + edit).
# Chat id: @public_username or -100xxxxxxxxxx. With numeric id, the bot resolves invite/username via getChat when Telegram exposes them.
# TELEGRAM_LISTINGS_CHANNEL_ID=-100xxxxxxxxxx

# Optional: membership gate uses this chat instead of the listings channel when set.
# If TELEGRAM_LISTINGS_CHANNEL_ID is unset, this id is also used to post listings and build the «open channel» link (single-channel mode).
# TELEGRAM_MEMBERSHIP_CHANNEL_ID=

# Optional: group/supergroup id for membership (@name or -100…). If set together with a channel id, user may join either (OR). If neither group nor channel id is configured, the gate stays off (unless you only use listings channel, which still counts as channel id).
# TELEGRAM_MEMBERSHIP_GROUP_ID=
# Optional invite link for the group join button (like TELEGRAM_CHANNEL_INVITE_URL).
# TELEGRAM_MEMBERSHIP_GROUP_INVITE_URL=

# Local/dev: set to true to allow using the bot without membership checks (do not use in production).
# TELEGRAM_DISABLE_MEMBERSHIP_GATE=false

# Optional explicit URL for «join» / «open channel» (e.g. https://t.me/+invite). Overrides API resolution when set.
# TELEGRAM_CHANNEL_INVITE_URL=

# USD/EUR → rial snapshot for the «نرخ زنده و معادل ریالی» menu (margani/pricedb TGJU JSON by default).
# IRR_RATES_TTL_SECONDS=300
# IRR_USD_JSON_URL=
# IRR_EUR_JSON_URL=
