# Copy to .env and fill in. Never commit .env.

# --- Monitoring ---
# ISO date: only alert/book slots strictly before this date.
CUTOFF_DATE=2026-07-07
CHECK_INTERVAL_MINUTES=15
PERSONS=1
LOCALE=en

# Comma-separated desk keys (defaults cover Haarlem, Amsterdam, Utrecht).
# DESKS=6b425ff9f87de136a36b813cccf26e23,AM,fa24ccf0acbc76a7793765937eaee440

# --- Telegram (optional but recommended) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Auto-book (optional; off by default) ---
AUTO_BOOK=false

# Required when AUTO_BOOK=true
EMAIL=
PHONE=
BIRTH_DATE=
FIRST_NAME=
LAST_NAME=
# Provide one of these (V-number usually starts with V, BSN is 9 digits):
V_NUMBER=
BSN=
